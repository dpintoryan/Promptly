# ============================================================
#  PromptPerfect Backend – Environment Variables
#  Copy this file to .env for local dev.
#  Set all of these in Railway's Variables tab for production.
#  NEVER commit your real .env to Git.
# ============================================================

# From OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# From MongoDB Atlas — connection string with username/password embedded
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/promptperfect?retryWrites=true&w=majority

# Random secret used to sign JWTs — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-long-random-secret-here

# From Google Cloud Console OAuth 2.0 client
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Port — Railway sets this automatically
PORT=3000
